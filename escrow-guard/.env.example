# API Server Settings
PORT=8000
HOST=0.0.0.0

# Band Pro SDK Configs
BAND_API_KEY=your_band_api_key_here
BAND_ROOM_ID=your_room_id_here

# Large Language Model (LLM) Providers
# Gemini is the default provider for development.
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (Claude) is designated for production and high-reasoning tasks.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Environment Settings
ENVIRONMENT=development
